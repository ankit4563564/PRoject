# Example Gradle properties for Diabo project
# API keys, endpoints, and other environment-specific values
# ----------------------------------------------------------
# Google ML Kit OCR does not require a key.

# Example placeholder values:
MLKIT_API_KEY=YOUR_MLKIT_API_KEY
OLLAMA_BASE_URL=http://10.0.2.2:11434/
OLLAMA_MODEL=llama3.1:8b

# Gradle properties for signing (optional)
# SIGNING_STORE_FILE=keystore.jks
# SIGNING_STORE_PASSWORD=your_store_password
# SIGNING_KEY_ALIAS=your_key_alias
# SIGNING_KEY_PASSWORD=your_key_password
