<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/purple_gradient">

    <!-- Header Section -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_chevron_right"
        android:rotation="180"
        android:background="@drawable/circle_white_alpha_15"
        android:padding="8dp"
        app:tint="@color/white"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Risk Factors"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@+id/btn_back"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Circular Progress -->
    <FrameLayout
        android:id="@+id/progress_container"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@+id/btn_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <ProgressBar
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            style="?android:attr/progressBarStyleHorizontal"
            android:progressDrawable="@drawable/circular_progress_white"
            android:max="5"
            android:progress="3"
            android:rotation="-90" />
            
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="of 5"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom Sheet Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@+id/progress_container"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Any related health conditions?"
                android:textColor="@color/diabetesHeaderPurple"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This helps us assess complication risks and customize monitoring."
                android:textColor="@color/graySubtext"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="20dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="3">

                        <!-- Unselected Toggle -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Hypertension"
                            android:textColor="@color/grayText"
                            android:gravity="center"
                            android:background="@drawable/edittext_bg"
                            android:paddingVertical="12dp"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="16dp"
                            app:drawableStartCompat="@drawable/ic_blood_pressure"
                            app:drawableTint="@color/graySubtext"
                            android:drawablePadding="8dp"
                            android:paddingHorizontal="16dp" />

                        <!-- Unselected Toggle -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Dyslipidemia"
                            android:textColor="@color/grayText"
                            android:gravity="center"
                            android:background="@drawable/edittext_bg"
                            android:paddingVertical="12dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="16dp"
                            app:drawableStartCompat="@drawable/ic_cholesterol"
                            app:drawableTint="@color/graySubtext"
                            android:drawablePadding="8dp"
                            android:paddingHorizontal="16dp" />
                            
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Neuropathy"
                            android:textColor="@color/grayText"
                            android:gravity="center"
                            android:background="@drawable/edittext_bg"
                            android:paddingVertical="12dp"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Retinopathy"
                            android:textColor="@color/grayText"
                            android:gravity="center"
                            android:background="@drawable/edittext_bg"
                            android:paddingVertical="12dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Kidney Disease"
                            android:textColor="@color/grayText"
                            android:gravity="center"
                            android:background="@drawable/edittext_bg"
                            android:paddingVertical="12dp"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="16dp" />

                        <!-- Selected Toggle -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Obesity"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/button_gradient"
                            android:paddingVertical="12dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="16dp"
                            app:drawableStartCompat="@drawable/ic_bmi"
                            app:drawableTint="@color/white"
                            android:drawablePadding="8dp"
                            android:paddingHorizontal="16dp" />
                    </GridLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/edittext_bg"
                        android:padding="16dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Family history of diabetes"
                                android:textColor="@color/diabetesHeaderPurple"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Parent or sibling with diabetes"
                                android:textColor="@color/graySubtext"
                                android:textSize="13sp" />
                        </LinearLayout>
                        
                        <Switch
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:theme="@style/Widget.AppCompat.CompoundButton.Switch" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/edittext_bg"
                        android:padding="16dp"
                        android:layout_marginBottom="12dp">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="History of severe hypoglycemia"
                                android:textColor="@color/diabetesHeaderPurple"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Required assistance in past"
                                android:textColor="@color/graySubtext"
                                android:textSize="13sp" />
                        </LinearLayout>
                        
                        <Switch
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false" />
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Step 3 of 5"
                    android:textColor="@color/graySubtext"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue \u2192"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:background="@drawable/button_gradient"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
