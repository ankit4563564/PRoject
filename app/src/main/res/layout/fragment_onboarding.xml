<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app_res="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:forceDarkAllowed="false"
    android:background="@drawable/purple_gradient">

    <!-- Icon Area -->
    <FrameLayout
        android:id="@+id/icon_container"
        android:layout_width="160dp"
        android:layout_height="160dp"
        app_res:layout_constraintTop_toTopOf="parent"
        app_res:layout_constraintBottom_toTopOf="@+id/content_card"
        app_res:layout_constraintStart_toStartOf="parent"
        app_res:layout_constraintEnd_toEndOf="parent"
        app_res:layout_constraintVertical_bias="0.4">

        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/circle_white_alpha_15" />

        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_white_alpha_10" />

        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:src="@drawable/heart_icon"
            app_res:tint="@color/colorAccent" />
    </FrameLayout>

    <!-- White Card Content -->
    <androidx.cardview.widget.CardView
        android:id="@+id/content_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app_res:cardBackgroundColor="@color/surfaceCardLight"
        app_res:cardCornerRadius="40dp"
        app_res:cardElevation="0dp"
        app_res:layout_constraintBottom_toBottomOf="parent"
        app_res:layout_constraintHeight_percent="0.65">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="30dp"
            android:paddingBottom="50dp">

            <!-- Badge -->
            <TextView
                android:id="@+id/badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_badge"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp"
                android:letterSpacing="0.2"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:background="@drawable/badge_outline"
                app_res:layout_constraintTop_toTopOf="parent"
                app_res:layout_constraintStart_toStartOf="parent"
                app_res:layout_constraintEnd_toEndOf="parent" />

            <!-- Title -->
            <TextView
                android:id="@+id/title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Your diabetes care, organized from day one"
                android:textColor="@color/onSurfaceHigh"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="20dp"
                app_res:layout_constraintTop_toBottomOf="@+id/badge"
                app_res:layout_constraintStart_toStartOf="parent"
                app_res:layout_constraintEnd_toEndOf="parent" />

            <!-- Feature List (RecyclerView normally, but static for now matching Swift) -->
            <LinearLayout
                android:id="@+id/feature_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="20dp"
                app_res:layout_constraintTop_toBottomOf="@+id/title">

                <!-- Feature 1 -->
                <include android:id="@+id/feature_1" layout="@layout/item_feature" />
                <!-- Feature 2 -->
                <include android:id="@+id/feature_2" layout="@layout/item_feature" />
                <!-- Feature 3 -->
                <include android:id="@+id/feature_3" layout="@layout/item_feature" />
                <!-- Feature 4 -->
                <include android:id="@+id/feature_4" layout="@layout/item_feature" />
            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="20dp"
                app_res:layout_constraintTop_toBottomOf="@+id/feature_list" />

            <!-- Continue Button -->
            <Button
                android:id="@+id/btn_continue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/continue_text"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingVertical="18dp"
                android:layout_marginHorizontal="30dp"
                android:background="@drawable/button_gradient"
                app_res:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
