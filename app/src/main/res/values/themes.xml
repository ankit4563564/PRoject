<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Diabo" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Surface and Background -->
        <item name="android:windowBackground">@color/surfaceBackground</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>

        <!-- Text Colors -->
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
        <item name="android:editTextColor">@color/textPrimary</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/surfaceBackground</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Diabo.NoActionBar" parent="Theme.Diabo">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Diabo.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.Diabo.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
